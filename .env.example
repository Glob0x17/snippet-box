# Server
PORT=5000
NODE_ENV=production

# Session
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string
# Set to 1 when serving over HTTPS behind a reverse proxy
TRUST_PROXY=0

# OIDC (PocketID, Authelia, Keycloak, etc.)
OIDC_ISSUER_URL=https://auth.example.com
OIDC_CLIENT_ID=snippet-box
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:5000/auth/callback
OIDC_SCOPES=openid profile email
# Optional: restrict access to a comma-separated list of emails (empty = anyone who can log in via the IdP)
OIDC_ALLOWED_EMAILS=
# Optional: post-logout redirect target (defaults to the app root)
OIDC_POST_LOGOUT_REDIRECT_URI=
