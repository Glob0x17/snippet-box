{
  "name": "snippet-box",
  "version": "2.0.0",
  "description": "Self-hosted snippet manager with OIDC authentication",
  "main": "build/server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "init": "npm install && npm install --prefix client",
    "dev:server": "nodemon",
    "dev:client": "npm run dev --prefix client",
    "dev": "npm-run-all -n --parallel dev:**",
    "build:clean": "rm -rf build public",
    "build:tsc": "tsc",
    "build:client": "npm run build --prefix client",
    "build:assets": "mkdir -p public && cp -r client/dist/. public/",
    "build": "npm-run-all -n build:clean build:tsc build:client build:assets",
    "start": "node build/server.js"
  },
  "keywords": [
    "snippets",
    "self-hosted",
    "oidc"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.1",
    "@types/node": "^22.10.0",
    "nodemon": "^3.1.7",
    "npm-run-all2": "^7.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.7",
    "express": "^5.0.1",
    "express-session": "^1.18.1",
    "openid-client": "^6.1.7",
    "sequelize": "^6.37.5",
    "session-file-store": "^1.5.0",
    "sqlite3": "^5.1.7",
    "umzug": "^3.8.2"
  }
}
